# Supabase 接続情報 (必須)
# Supabase ダッシュボード > Project Settings > API から取得します。
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
# service_role シークレットキー。サーバー側でのみ使用し、絶対に公開しないこと。
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# 任意: 設定画面 (/settings) でも登録できます
# GitHub トークン (PR差分・レビューコメント取得用。未設定でも動くがレート制限が厳しい)
# GITHUB_TOKEN=ghp_xxx
# Anthropic APIキー (AIフィードバック用)
# ANTHROPIC_API_KEY=sk-ant-xxx
